rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS — citizens can read/update own doc; officers/admins can read all
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin']);
    }

    // CASES — citizens can create; can read own cases; officers/admins read all
    match /cases/{caseId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
        (resource.data.submittedBy == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['officer', 'admin']);
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['officer', 'admin'];

      // EVIDENCE subcollection
      match /evidence/{evidenceId} {
        allow read, write: if request.auth != null;
      }
    }

    // NOTIFICATIONS — users can read their own; officers/admins can write
    match /notifications/{userId}/items/{notifId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }

    // AUDIT LOGS — anyone authenticated can write; only admins can read
    match /auditLogs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
